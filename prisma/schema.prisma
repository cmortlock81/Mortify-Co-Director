generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum UserRole { admin sales project_manager support finance read_only }
enum OpportunityStatus { new qualified proposal negotiation won lost }
enum ProjectStatus { planned active on_hold completed cancelled }
enum TicketStatus { open in_progress waiting_customer resolved closed }
enum InvoiceStatus { draft sent part_paid paid overdue void }

model User { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid name String? email String @unique password_hash String role UserRole @default(read_only) created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model Company { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid name String domain String? industry String? phone String? address String? status String? contacts Contact[] opportunities Opportunity[] projects Project[] tickets Ticket[] invoices Invoice[] activities Activity[] created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model Contact { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid company_id String @db.Uuid company Company @relation(fields:[company_id], references:[id]) first_name String last_name String email String? phone String? title String? created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model Lead { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid company_id String? @db.Uuid contact_id String? @db.Uuid source String? status String? estimated_value_minor Int @default(0) notes String? created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model Opportunity { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid company_id String @db.Uuid company Company @relation(fields:[company_id], references:[id]) name String stage OpportunityStatus @default(new) deal_value_minor Int @default(0) probability Int @default(10) expected_close_date DateTime? quotes Quote[] project Project? activities Activity[] created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model Quote { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid opportunity_id String @db.Uuid opportunity Opportunity @relation(fields:[opportunity_id], references:[id]) quote_number String @unique status String @default("draft") subtotal_minor Int @default(0) tax_minor Int @default(0) total_minor Int @default(0) valid_until DateTime? lines QuoteLine[] created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model QuoteLine { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid quote_id String @db.Uuid quote Quote @relation(fields:[quote_id], references:[id]) description String quantity Int @default(1) unit_price_minor Int @default(0) tax_rate Decimal @default(20) created_at DateTime @default(now()) }
model Project { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid company_id String @db.Uuid company Company @relation(fields:[company_id], references:[id]) opportunity_id String? @unique @db.Uuid opportunity Opportunity? @relation(fields:[opportunity_id], references:[id]) name String status ProjectStatus @default(planned) priority Int @default(3) budget_minor Int @default(0) estimated_cost_minor Int @default(0) actual_cost_minor Int @default(0) progress Int @default(0) due_date DateTime? tasks Task[] milestones Milestone[] tickets Ticket[] invoices Invoice[] activities Activity[] created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model Task { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid project_id String @db.Uuid project Project @relation(fields:[project_id], references:[id]) title String status String @default("todo") assignee String? due_date DateTime? created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model Milestone { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid project_id String @db.Uuid project Project @relation(fields:[project_id], references:[id]) name String due_date DateTime? completed_at DateTime? created_at DateTime @default(now()) }
model Ticket { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid company_id String @db.Uuid company Company @relation(fields:[company_id], references:[id]) project_id String? @db.Uuid project Project? @relation(fields:[project_id], references:[id]) subject String priority String @default("medium") status TicketStatus @default(open) internal_notes String? sla_due_at DateTime? comments TicketComment[] activities Activity[] created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model TicketComment { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid ticket_id String @db.Uuid ticket Ticket @relation(fields:[ticket_id], references:[id]) body String customer_visible Boolean @default(false) created_at DateTime @default(now()) }
model Invoice { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid company_id String @db.Uuid company Company @relation(fields:[company_id], references:[id]) project_id String? @db.Uuid project Project? @relation(fields:[project_id], references:[id]) invoice_number String @unique status InvoiceStatus @default(draft) subtotal_minor Int @default(0) tax_minor Int @default(0) total_minor Int @default(0) due_date DateTime? lines InvoiceLine[] payments Payment[] activities Activity[] created_at DateTime @default(now()) updated_at DateTime @default(now()) }
model InvoiceLine { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid invoice_id String @db.Uuid invoice Invoice @relation(fields:[invoice_id], references:[id]) description String quantity Int @default(1) unit_price_minor Int @default(0) tax_rate Decimal @default(20) created_at DateTime @default(now()) }
model Payment { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid invoice_id String @db.Uuid invoice Invoice @relation(fields:[invoice_id], references:[id]) amount_minor Int paid_at DateTime @default(now()) method String? reference String? created_at DateTime @default(now()) }
model Activity { id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid company_id String? @db.Uuid company Company? @relation(fields:[company_id], references:[id]) opportunity_id String? @db.Uuid opportunity Opportunity? @relation(fields:[opportunity_id], references:[id]) project_id String? @db.Uuid project Project? @relation(fields:[project_id], references:[id]) ticket_id String? @db.Uuid ticket Ticket? @relation(fields:[ticket_id], references:[id]) invoice_id String? @db.Uuid invoice Invoice? @relation(fields:[invoice_id], references:[id]) type String body String created_at DateTime @default(now()) }
